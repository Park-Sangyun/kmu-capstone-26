# =================================================================
# [ Windows 시스템 파일 ]
# =================================================================
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# =================================================================
# [ IDE 및 개발 도구 ]
# =================================================================
# IntelliJ IDEA
.idea/
*.iml
out/
gen/

# VS Code
.vscode/
.history/
*.code-workspace

# =================================================================
# [ 백엔드 (Spring Boot / Gradle) ]
# =================================================================
backend/.gradle/
backend/build/
backend/out/
backend/bin/

# 로컬 DB 설정 및 보안 파일 (비밀번호 포함)
# 팀원에게는 application.yml.example을 공유하세요!
backend/src/main/resources/application.yml

# 로그 파일
backend/*.log

# =================================================================
# [ 프론트엔드 (React / Vite / Node.js) ]
# =================================================================
# 용량이 매우 크므로 반드시 제외
frontend/node_modules/

# 빌드 결과물
frontend/dist/
frontend/build/

# 환경 변수 (API 키 등 보안)
frontend/.env
frontend/.env.local
frontend/*.local

# 로그 파일
frontend/npm-debug.log*
frontend/yarn-debug.log*

# =================================================================
# [ 기타 ]
# =================================================================
*.tmp
*.bak
*.swp